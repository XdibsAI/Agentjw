"""
Executive Brain Complete - V3.5
Integrasi semua komponen: Experience, Confidence, Planner, Action Ranking
"""

import json
from pathlib import Path
from datetime import datetime
from typing import Dict, List, Any, Optional
from dataclasses import dataclass, field


@dataclass
class ExecutiveDecision:
    """Keputusan lengkap dari Executive Brain"""
    timestamp: str
    user_request: str
    intent: str
    action: str
    target: str
    confidence: float
    confidence_level: str
    action_rank: int
    action_priority: str
    plan: List[str]
    reasoning: List[str]
    experience_used: int
    similar_experiences: List[str]
    success_prediction: float
    estimated_duration: float


class ExecutiveBrainComplete:
    """
    Executive Brain Complete - V3.5
    Semua komponen terintegrasi
    """

    def __init__(self, memory_dir: str = "memory"):
        self.memory_dir = Path(memory_dir)
        self.decisions_file = self.memory_dir / "executive_decisions_complete.json"
        self.decisions: List[ExecutiveDecision] = []
        self._load_decisions()
        
        # Init semua komponen
        self._init_components()

    def _init_components(self):
        """Init semua komponen"""
        try:
            from sicuan.core.experience_engine import get_experience_engine
            self.experience_engine = get_experience_engine()
        except:
            self.experience_engine = None
        
        try:
            from sicuan.core.adaptive_confidence import get_adaptive_confidence
            self.confidence_engine = get_adaptive_confidence()
        except:
            self.confidence_engine = None
        
        try:
            from sicuan.core.planner_optimizer import get_planner_optimizer
            self.planner_optimizer = get_planner_optimizer()
        except:
            self.planner_optimizer = None
        
        try:
            from sicuan.core.action_ranker import get_action_ranker
            self.action_ranker = get_action_ranker()
        except:
            self.action_ranker = None
        
        try:
            from sicuan.core.self_review_data import get_self_review
            self.self_review = get_self_review()
        except:
            self.self_review = None

    def decide(self, user_request: str, context: Dict = None) -> ExecutiveDecision:
        """
        Ambil keputusan dengan semua komponen
        """
        context = context or {}
        intent = context.get("intent", "unknown")
        project = context.get("project", "unknown")
        
        # 1. Dapatkan similar experiences
        similar_experiences = []
        if self.experience_engine:
            similar_experiences = self.experience_engine.get_similar_experiences(
                user_request, intent, limit=3
            )
        
        # 2. Dapatkan plan optimal dari planner
        optimal_plan = None
        if self.planner_optimizer:
            plan_rec = self.planner_optimizer.get_plan_recommendation(intent, user_request)
            optimal_plan = plan_rec.get("recommended_actions", [])
        
        # 3. Pilih action utama dari plan
        action = optimal_plan[0] if optimal_plan else "analyze_project"
        
        # 4. Hitung adaptive confidence
        confidence_result = None
        if self.confidence_engine:
            confidence_result = self.confidence_engine.calculate_confidence(
                action=action,
                user_request=user_request,
                similar_experiences=similar_experiences
            )
        
        confidence = confidence_result.get("confidence", 0.5) if confidence_result else 0.5
        confidence_level = confidence_result.get("level", "MEDIUM") if confidence_result else "MEDIUM"
        
        # 5. Dapatkan action rank
        action_rank = None
        if self.action_ranker:
            rank = self.action_ranker.get_action_rank(action)
            action_rank = rank.rank
            action_priority = rank.priority
        
        # 6. Prediksi sukses
        success_prediction = self._predict_success(action, confidence, similar_experiences)
        
        # 7. Estimasi durasi
        estimated_duration = self._estimate_duration(action, similar_experiences)
        
        # 8. Build reasoning
        reasoning = self._build_reasoning(
            user_request, intent, action, confidence, 
            similar_experiences, optimal_plan
        )
        
        # 9. Simpan decision
        decision = ExecutiveDecision(
            timestamp=datetime.now().isoformat(),
            user_request=user_request,
            intent=intent,
            action=action,
            target=project,
            confidence=confidence,
            confidence_level=confidence_level,
            action_rank=action_rank or 0,
            action_priority=action_priority or "MEDIUM",
            plan=optimal_plan or [action],
            reasoning=reasoning,
            experience_used=len(similar_experiences),
            similar_experiences=[e.id for e in similar_experiences[:3]] if similar_experiences else [],
            success_prediction=success_prediction,
            estimated_duration=estimated_duration
        )
        
        self.decisions.append(decision)
        self._save_decisions()
        
        return decision

    def _predict_success(self, action: str, confidence: float, similar_experiences: List) -> float:
        """Prediksi sukses berdasarkan data historis"""
        # Base: confidence * 0.6 + historical_success * 0.4
        historical_success = 0.5
        
        # Dari experience engine
        if self.experience_engine:
            stats = self.experience_engine.get_stats()
            action_stats = stats.get("action_stats", {})
            if action in action_stats:
                historical_success = min(1.0, action_stats[action] / 10)  # 10 experiences = 100%
        
        # Dari action ranker
        if self.action_ranker:
            rank = self.action_ranker.get_action_rank(action)
            historical_success = max(historical_success, rank.success_rate)
        
        prediction = (confidence * 0.6) + (historical_success * 0.4)
        return min(1.0, prediction)

    def _estimate_duration(self, action: str, similar_experiences: List) -> float:
        """Estimasi durasi action"""
        # Default durations
        durations = {
            "scan_project": 5.0,
            "analyze_project": 10.0,
            "build_project": 15.0,
            "repair_project": 12.0,
            "modify_logic": 8.0,
            "run_bot": 3.0,
            "status": 2.0,
            "list_projects": 1.0,
        }
        
        base_duration = durations.get(action, 10.0)
        
        # Adjust berdasarkan experience
        if self.experience_engine and similar_experiences:
            avg_duration = sum(e.duration for e in similar_experiences[:3]) / min(3, len(similar_experiences))
            if avg_duration > 0:
                base_duration = (base_duration + avg_duration) / 2
        
        return round(base_duration, 1)

    def _build_reasoning(self, user_request: str, intent: str, action: str,
                         confidence: float, similar_experiences: List, plan: List) -> List[str]:
        """Build reasoning lengkap"""
        reasons = []
        
        # 1. Intent
        reasons.append(f"Intent terdeteksi: {intent}")
        
        # 2. Plan
        if plan:
            reasons.append(f"Plan optimal: {' → '.join(plan)}")
        
        # 3. Action
        reasons.append(f"Action utama: {action}")
        
        # 4. Confidence
        level = "tinggi" if confidence >= 0.8 else "sedang" if confidence >= 0.6 else "rendah"
        reasons.append(f"Confidence: {confidence:.1%} ({level})")
        
        # 5. Experience
        if similar_experiences:
            reasons.append(f"Menggunakan {len(similar_experiences)} pengalaman serupa")
        else:
            reasons.append("Tidak ada pengalaman serupa")
        
        # 6. Action rank
        if self.action_ranker:
            rank = self.action_ranker.get_action_rank(action)
            reasons.append(f"Action rank: #{rank.rank} ({rank.priority})")
        
        # 7. Prediksi
        reasons.append(f"Prediksi sukses: {self._predict_success(action, confidence, similar_experiences):.1%}")
        
        return reasons

    def get_stats(self) -> Dict:
        """Dapatkan statistik decision"""
        total = len(self.decisions)
        if total == 0:
            return {"total": 0}
        
        # Per action
        action_stats = {}
        for d in self.decisions:
            action_stats[d.action] = action_stats.get(d.action, 0) + 1
        
        # Per intent
        intent_stats = {}
        for d in self.decisions:
            intent_stats[d.intent] = intent_stats.get(d.intent, 0) + 1
        
        # Avg confidence
        avg_confidence = sum(d.confidence for d in self.decisions) / total
        
        return {
            "total": total,
            "action_stats": action_stats,
            "intent_stats": intent_stats,
            "avg_confidence": avg_confidence,
            "avg_success_prediction": sum(d.success_prediction for d in self.decisions) / total,
            "latest": self.decisions[-1] if self.decisions else None
        }

    def print_summary(self):
        """Print summary ke console"""
        stats = self.get_stats()
        
        print("\n" + "=" * 70)
        print("🧠 EXECUTIVE BRAIN COMPLETE - V3.5")
        print("=" * 70)
        print(f"Total Decisions      : {stats.get('total', 0)}")
        print(f"Avg Confidence       : {stats.get('avg_confidence', 0):.1%}")
        print(f"Avg Success Prediction: {stats.get('avg_success_prediction', 0):.1%}")
        
        if stats.get('action_stats'):
            print("\n📊 Per Action:")
            for action, count in sorted(stats['action_stats'].items(), key=lambda x: x[1], reverse=True):
                print(f"  {action}: {count}")
        
        if stats.get('intent_stats'):
            print("\n📊 Per Intent:")
            for intent, count in sorted(stats['intent_stats'].items(), key=lambda x: x[1], reverse=True):
                print(f"  {intent}: {count}")
        
        if stats.get('latest'):
            latest = stats['latest']
            print(f"\n📋 Latest Decision:")
            print(f"  Request: {latest.user_request[:50]}...")
            print(f"  Action: {latest.action}")
            print(f"  Confidence: {latest.confidence:.1%} ({latest.confidence_level})")
            print(f"  Plan: {' → '.join(latest.plan)}")
            print(f"  Reasoning: {latest.reasoning[0] if latest.reasoning else 'N/A'}")
        
        print("=" * 70)


# Singleton
_brain = None

def get_executive_brain_complete():
    global _brain
    if _brain is None:
        _brain = ExecutiveBrainComplete()
    return _brain

    def _load_decisions(self):
        """Load decisions dari disk"""
        if self.decisions_file.exists():
            try:
                data = json.loads(self.decisions_file.read_text())
                decisions_data = data.get("decisions", [])
                self.decisions = [ExecutiveDecision(**d) for d in decisions_data]
                print(f"[BRAIN] Loaded {len(self.decisions)} decisions")
            except:
                self.decisions = []
        else:
            self.decisions = []

    def _save_decisions(self):
        """Save decisions ke disk"""
        data = {
            "decisions": [d.__dict__ for d in self.decisions],
            "updated_at": datetime.now().isoformat()
        }
        self.decisions_file.write_text(json.dumps(data, indent=2))
