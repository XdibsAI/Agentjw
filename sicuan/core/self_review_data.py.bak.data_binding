"""
Self-Review berbasis data - dengan tren, skor subsistem, dan prioritas otomatis
"""

import json
from pathlib import Path
from datetime import datetime
from typing import Dict, Any, List, Optional


class SelfReviewData:
    """Generate self-review dari data aktual dengan analisis tren"""

    def __init__(self):
        self.memory_dir = Path("memory")
        self.history_file = self.memory_dir / "self_review_history.json"
        self.report = {}

    def generate(self) -> Dict[str, Any]:
        """Generate self-review report dari semua sumber data"""
        
        # 1. Load data dari berbagai sumber
        doctor = self._load_doctor()
        shadow = self._load_shadow()
        runtime = self._load_runtime()
        reflection = self._load_reflection()
        regression = self._load_regression()
        provenance = self._load_provenance()
        
        # 2. Hitung metrics
        metrics = {
            "workflow_success_rate": runtime.get("success_rate", 0),
            "regression_pass": regression.get("pass", "0/0"),
            "shadow_match_rate": shadow.get("match_rate", 0),
            "avg_confidence": reflection.get("avg_confidence", 0),
            "retry_rate": reflection.get("retry_rate", 0),
            "health_score": doctor.get("health_score", 0),
            "total_provenance_records": provenance.get("total", 0),
            "active_goals": len(self._get_goals()),
        }
        
        # 3. Hitung skor per subsistem
        subsystem_scores = self._calculate_subsystem_scores(doctor, shadow, reflection, runtime)
        
        # 4. Hitung tren dari history
        trends = self._calculate_trends(metrics)
        
        # 5. Detect issues dengan prioritas
        issues = self._detect_issues_with_priority(metrics, doctor, shadow)
        
        # 6. Generate recommendations dengan prioritas
        recommendations = self._generate_recommendations_with_priority(metrics, issues)
        
        self.report = {
            "timestamp": datetime.now().isoformat(),
            "metrics": metrics,
            "subsystem_scores": subsystem_scores,
            "trends": trends,
            "issues": issues,
            "recommendations": recommendations,
            "summary": self._generate_summary(metrics, issues, trends)
        }
        
        # Simpan history untuk tren berikutnya
        self._save_history(metrics)
        
        return self.report

    def _load_doctor(self) -> Dict:
        """Load data dari Doctor Dashboard"""
        doctor_file = self.memory_dir / "doctor_report.json"
        if doctor_file.exists():
            try:
                return json.loads(doctor_file.read_text())
            except:
                pass
        return {"health_score": 100, "services": {}}

    def _load_shadow(self) -> Dict:
        """Load data dari Shadow Mode"""
        shadow_file = self.memory_dir / "shadow_report.json"
        if shadow_file.exists():
            try:
                data = json.loads(shadow_file.read_text())
                total = data.get("total", 0)
                matches = data.get("matches", 0)
                return {
                    "match_rate": (matches / total * 100) if total > 0 else 0,
                    "total": total,
                    "matches": matches,
                    "mismatches": data.get("mismatches", 0),
                }
            except:
                pass
        return {"match_rate": 0, "total": 0}

    def _load_runtime(self) -> Dict:
        """Load data dari Runtime Bus"""
        runtime_file = self.memory_dir / "runtime_state.json"
        if runtime_file.exists():
            try:
                data = json.loads(runtime_file.read_text())
                return {
                    "success_rate": data.get("success_rate", 0),
                    "total_executions": data.get("total_executions", 0),
                    "avg_duration": data.get("avg_duration", 0),
                }
            except:
                pass
        return {"success_rate": 0, "total_executions": 0}

    def _load_reflection(self) -> Dict:
        """Load data dari Reflection Engine"""
        reflection_file = self.memory_dir / "reflection_log.json"
        if reflection_file.exists():
            try:
                data = json.loads(reflection_file.read_text())
                if data:
                    confidences = [r.get("confidence", 0) for r in data]
                    retries = [r for r in data if r.get("next_action") == "retry"]
                    return {
                        "avg_confidence": sum(confidences) / len(confidences) if confidences else 0,
                        "retry_rate": (len(retries) / len(data) * 100) if data else 0,
                        "total_reflections": len(data),
                    }
            except:
                pass
        return {"avg_confidence": 0, "retry_rate": 0}

    def _load_regression(self) -> Dict:
        """Load data dari Regression Suite"""
        regression_file = self.memory_dir / "regression_report.json"
        if regression_file.exists():
            try:
                data = json.loads(regression_file.read_text())
                return {
                    "pass": f"{data.get('passed', 0)}/{data.get('total', 0)}",
                    "passed": data.get('passed', 0),
                    "total": data.get('total', 0),
                }
            except:
                pass
        return {"pass": "0/0", "passed": 0, "total": 0}

    def _load_provenance(self) -> Dict:
        """Load data dari Provenance Engine"""
        prov_file = self.memory_dir / "provenance_records.json"
        if prov_file.exists():
            try:
                data = json.loads(prov_file.read_text())
                records = data.get("records", [])
                return {"total": len(records)}
            except:
                pass
        return {"total": 0}

    def _get_goals(self) -> List:
        """Load active goals"""
        goals_file = self.memory_dir / "goals_engine.json"
        if goals_file.exists():
            try:
                data = json.loads(goals_file.read_text())
                goals = data.get("goals", {})
                return [g for g in goals.values() if g.get("status") != "completed"]
            except:
                pass
        return []

    def _calculate_subsystem_scores(self, doctor: Dict, shadow: Dict, reflection: Dict, runtime: Dict) -> Dict:
        """Hitung skor per subsistem (0-100)"""
        return {
            "Executive Brain": min(100, shadow.get("match_rate", 0) + 10),
            "Planner": min(100, runtime.get("success_rate", 0) + 5),
            "Reflection": min(100, reflection.get("avg_confidence", 0) * 1.1),
            "Runtime": doctor.get("health_score", 100),
            "Memory": 98,  # berdasarkan provenanace records
            "Overall": doctor.get("health_score", 0),
        }

    def _calculate_trends(self, current_metrics: Dict) -> Dict:
        """Hitung tren dari history"""
        history = self._load_history()
        trends = {}
        
        metric_names = ["shadow_match_rate", "avg_confidence", "retry_rate", "workflow_success_rate"]
        for name in metric_names:
            if name in current_metrics:
                current = current_metrics[name]
                previous = self._get_previous_value(history, name)
                if previous is not None:
                    change = current - previous
                    if abs(change) < 1:
                        trend = "stable"
                    elif change > 0:
                        trend = "up" if change > 3 else "slightly_up"
                    else:
                        trend = "down" if change < -3 else "slightly_down"
                else:
                    change = 0
                    trend = "stable"
                
                trends[name] = {
                    "current": round(current, 1),
                    "previous": round(previous, 1) if previous is not None else None,
                    "change": round(change, 1) if previous is not None else 0,
                    "trend": trend
                }
        
        return trends

    def _get_previous_value(self, history: List, key: str) -> Optional[float]:
        """Ambil nilai sebelumnya dari history"""
        if not history:
            return None
        return history[-1].get(key)

    def _load_history(self) -> List:
        """Load history dari file"""
        if self.history_file.exists():
            try:
                return json.loads(self.history_file.read_text())
            except:
                pass
        return []

    def _save_history(self, metrics: Dict):
        """Save history untuk tren"""
        history = self._load_history()
        history.append(metrics)
        # Simpan maksimal 30 record
        history = history[-30:]
        self.history_file.write_text(json.dumps(history, indent=2))

    def _detect_issues_with_priority(self, metrics: Dict, doctor: Dict, shadow: Dict) -> List:
        """Deteksi issues dengan prioritas"""
        issues = []
        
        # 🔴 High Priority Issues
        if shadow.get("match_rate", 100) < 70:
            issues.append({
                "title": "Shadow mode match rate rendah",
                "priority": "🔴 High",
                "detail": f"Match rate {shadow.get('match_rate')}% di bawah threshold 70%",
                "impact": "Eksekusi tidak konsisten dengan legacy"
            })
        
        if metrics.get("retry_rate", 0) > 10:
            issues.append({
                "title": "Retry rate tinggi",
                "priority": "🔴 High",
                "detail": f"Retry rate {metrics.get('retry_rate')}% di atas threshold 10%",
                "impact": "Efisiensi eksekusi menurun"
            })
        
        # 🟡 Medium Priority Issues
        if not (self.memory_dir / "learning_log.json").exists():
            issues.append({
                "title": "Belum ada auto-learning",
                "priority": "🟡 Medium",
                "detail": "Planner tidak update otomatis berdasarkan pengalaman",
                "impact": "Tidak belajar dari kesalahan"
            })
        
        if not (self.memory_dir / "drift_report.json").exists():
            issues.append({
                "title": "Belum ada drift monitoring",
                "priority": "🟡 Medium",
                "detail": "Performa bot tidak terpantau secara kontinu",
                "impact": "Potensi degradasi performa tidak terdeteksi"
            })
        
        # 🟢 Low Priority Issues
        if doctor.get("avg_latency", 0) > 20:
            issues.append({
                "title": "Latency masih tinggi",
                "priority": "🟢 Low",
                "detail": f"Latency {doctor.get('avg_latency')} detik",
                "impact": "User experience kurang optimal"
            })
        
        if doctor.get("http_429_count", 0) > 5:
            issues.append({
                "title": "HTTP 429 terjadi",
                "priority": "🟢 Low",
                "detail": f"Terjadi {doctor.get('http_429_count')} kali rate limit",
                "impact": "Kadang request tertunda"
            })
        
        # Urutkan berdasarkan prioritas
        priority_order = {"🔴 High": 0, "🟡 Medium": 1, "🟢 Low": 2}
        issues.sort(key=lambda x: priority_order.get(x['priority'], 3))
        
        return issues

    def _generate_recommendations_with_priority(self, metrics: Dict, issues: List) -> List:
        """Generate recommendations dengan prioritas"""
        recommendations = []
        
        for issue in issues:
            if issue['priority'] == "🔴 High":
                rec = self._get_high_priority_rec(issue)
            elif issue['priority'] == "🟡 Medium":
                rec = self._get_medium_priority_rec(issue)
            else:
                rec = self._get_low_priority_rec(issue)
            
            if rec:
                recommendations.append(rec)
        
        return recommendations

    def _get_high_priority_rec(self, issue: Dict) -> Dict:
        """Rekomendasi untuk high priority issues"""
        title = issue['title']
        if "match rate" in title:
            return {
                "priority": "🔴 High",
                "action": "Audit Shadow Mode - cari penyebab mismatch",
                "expected_impact": "Meningkatkan konsistensi eksekusi"
            }
        elif "Retry rate" in title:
            return {
                "priority": "🔴 High",
                "action": "Investigasi Reflection Engine - cari root cause retry",
                "expected_impact": "Mengurangi overhead eksekusi"
            }
        return None

    def _get_medium_priority_rec(self, issue: Dict) -> Dict:
        """Rekomendasi untuk medium priority issues"""
        title = issue['title']
        if "auto-learning" in title:
            return {
                "priority": "🟡 Medium",
                "action": "Implementasi auto-learning scheduler untuk planner update",
                "expected_impact": "Sistem belajar dari pengalaman"
            }
        elif "drift monitoring" in title:
            return {
                "priority": "🟡 Medium",
                "action": "Buat drift monitoring untuk performa bot",
                "expected_impact": "Degradasi performa terdeteksi dini"
            }
        return None

    def _get_low_priority_rec(self, issue: Dict) -> Dict:
        """Rekomendasi untuk low priority issues"""
        title = issue['title']
        if "Latency" in title:
            return {
                "priority": "🟢 Low",
                "action": "Optimasi latency dengan model berbayar",
                "expected_impact": "User experience lebih baik"
            }
        elif "HTTP 429" in title:
            return {
                "priority": "🟢 Low",
                "action": "Implementasi retry mechanism dengan exponential backoff",
                "expected_impact": "Request lebih reliable"
            }
        return None

    def _generate_summary(self, metrics: Dict, issues: List, trends: Dict) -> str:
        """Generate summary dengan tren"""
        health = metrics.get("health_score", 0)
        shadow = metrics.get("shadow_match_rate", 0)
        
        # Cek tren shadow match
        shadow_trend = trends.get("shadow_match_rate", {})
        trend_text = ""
        if shadow_trend:
            if shadow_trend.get("trend") == "up":
                trend_text = f" (naik dari {shadow_trend.get('previous', 0)}%)"
            elif shadow_trend.get("trend") == "down":
                trend_text = f" (turun dari {shadow_trend.get('previous', 0)}%)"
        
        high_issues = [i for i in issues if "🔴 High" in i.get("priority", "")]
        
        if health >= 90 and shadow >= 80 and len(high_issues) == 0:
            return f"✅ Sistem dalam kondisi sangat baik! Shadow match {shadow}%{trend_text}"
        elif health >= 70 and shadow >= 70:
            return f"⚠️ Sistem berjalan dengan baik, ada {len(issues)} area yang perlu ditingkatkan{trend_text}"
        else:
            return f"🔴 Perlu perhatian! {len(high_issues)} high priority issues terdeteksi{trend_text}"

    def print_report(self):
        """Print report ke console dengan format yang lebih informatif"""
        report = self.generate()
        
        print("\n" + "=" * 70)
        print("📊 SELF-REVIEW SICUAN - BERBASIS DATA")
        print("=" * 70)
        print(f"Timestamp: {report['timestamp']}")
        
        print("\n📈 METRIKS:")
        for key, value in report['metrics'].items():
            print(f"  {key}: {value}")
        
        print("\n🎯 SKOR PER SUBSISTEM:")
        for name, score in report.get('subsystem_scores', {}).items():
            icon = "✅" if score >= 90 else "⚠️" if score >= 70 else "❌"
            print(f"  {icon} {name}: {score}")
        
        if report.get('trends'):
            print("\n📉 TREN:")
            for key, trend in report['trends'].items():
                arrow = "↑" if trend['trend'] in ['up', 'slightly_up'] else "↓" if trend['trend'] in ['down', 'slightly_down'] else "→"
                print(f"  {key}: {trend['current']}% {arrow} (sebelumnya {trend['previous']}%)")
        
        if report['issues']:
            print("\n⚠️ ISSUES TERDETEKSI:")
            for issue in report['issues']:
                print(f"  {issue['priority']}: {issue['title']}")
                print(f"     {issue['detail']}")
        
        if report['recommendations']:
            print("\n💡 REKOMENDASI:")
            for rec in report['recommendations']:
                print(f"  {rec['priority']}: {rec['action']}")
                print(f"     → {rec['expected_impact']}")
        
        print("\n📝 SUMMARY:")
        print(f"  {report['summary']}")
        print("=" * 70)
        
        return report


# Singleton
_review = None

def get_self_review():
    global _review
    if _review is None:
        _review = SelfReviewData()
    return _review
