"""
Runtime Verifier — Verifikasi yang sebenarnya
"""

import subprocess
import time
from pathlib import Path
from typing import Dict, List, Optional


class RuntimeVerifier:
    """
    Runtime Verification yang proper:
    1. Apply patch
    2. Restart bot
    3. Tunggu 30 detik
    4. Monitor log untuk error yang sama
    5. Jika error masih ada → FAIL
    6. Jika error hilang → PASS
    """

    def __init__(self, project_dir: str = "/home/dibs/agentjw/projects/godmeme_bot"):
        self.project_dir = Path(project_dir)
        self.log_file = self.project_dir / "trading_bot_live.log"
        self.bot_log = self.project_dir / "bot.log"
        self.paper_log = self.project_dir / "paper_24h.log"
        self.error_patterns = [
            "AttributeError",
            "ModuleNotFoundError",
            "SyntaxError",
            "IndentationError",
            "TypeError",
            "KeyError",
            "ValueError",
            "Exception"
        ]



    def _check_worker_health(self) -> Dict:
        """Cek health semua worker internal"""
        result = {
            "token_monitor": False,
            "position_monitor": False,
            "strategy_loop": False,
            "last_heartbeat": 0,
            "exception_count": 0,
            "workers_alive": 0,
            "message": ""
        }
        
        # Cek multiple log files
        log_files = [self.log_file, self.bot_log, self.paper_log]
        log_exists = any(f.exists() for f in log_files)
        
        if not log_exists:
            result["message"] = "No log files found"
            return result
        
        # Cari log yang paling baru
        latest_log = None
        for f in log_files:
            if f.exists():
                if latest_log is None or f.stat().st_mtime > latest_log.stat().st_mtime:
                    latest_log = f
        
        if latest_log is None:
            result["message"] = "No log files found"
            return result
        
        try:
            with open(self.log_file, "r") as f:
                lines = f.readlines()[-100:]
            
            # Cek token monitor
            token_lines = [l for l in lines if "Token monitor" in l]
            if token_lines:
                last_token = token_lines[-1]
                if "started" in last_token or "scanning" in last_token:
                    result["token_monitor"] = True
            
            # Cek position monitor
            pos_lines = [l for l in lines if "Position monitor" in l]
            if pos_lines:
                last_pos = pos_lines[-1]
                if "started" in last_pos or "monitoring" in last_pos:
                    result["position_monitor"] = True
            
            # Cek strategy loop
            strategy_lines = [l for l in lines if "Strategy" in l and ("running" in l or "started" in l)]
            if strategy_lines:
                result["strategy_loop"] = True
            
            # Cek exception count
            exceptions = [l for l in lines if "ERROR" in l or "Exception" in l]
            result["exception_count"] = len(exceptions)
            
            # Cek heartbeat (log terakhir)
            if lines:
                last_line = lines[-1]
                try:
                    # Parse timestamp (contoh: "2026-07-07 17:42:29")
                    import re
                    match = re.search(r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})', last_line)
                    if match:
                        from datetime import datetime
                        last_time = datetime.fromisoformat(match.group(1).replace(" ", "T"))
                        now = datetime.now()
                        seconds_ago = (now - last_time).total_seconds()
                        result["last_heartbeat"] = int(seconds_ago)
                except:
                    pass
            
            # Hitung workers alive
            workers = [result["token_monitor"], result["position_monitor"], result["strategy_loop"]]
            result["workers_alive"] = sum(workers)
            
            if result["workers_alive"] >= 2:
                result["message"] = f"{result['workers_alive']}/3 workers alive"
            else:
                result["message"] = f"Only {result['workers_alive']}/3 workers alive"
                
        except Exception as e:
            result["message"] = f"Health check error: {e}"
        
        return result

    def verify(self, error: str, wait_time: int = 30) -> Dict:
        """
        Verifikasi runtime yang sebenarnya
        Returns:
        {
            "success": bool,
            "error_found": bool,
            "errors": list,
            "message": str
        }
        """
        result = {
            "success": False,
            "error_found": False,
            "errors": [],
            "message": ""
        }

        # 1. Restart bot
        print("[VERIFY] Restarting bot...")
        if not self._restart_bot():
            result["message"] = "Bot restart failed"
            return result

        # 2. Tunggu agar bot berjalan dan log terisi
        print(f"[VERIFY] Waiting {wait_time}s for runtime...")
        time.sleep(wait_time)

        # 3. Cek log
        print("[VERIFY] Checking logs...")
        errors = self._check_logs_for_error(error)

        if errors:
            result["error_found"] = True
            result["errors"] = errors
            result["message"] = f"Found {len(errors)} errors in log"
            result["success"] = False
            print(f"[VERIFY] ❌ Errors found: {len(errors)}")
        else:
            result["success"] = True
            result["message"] = "No errors found in log"
            print("[VERIFY] ✅ No errors found")

        return result

    def _restart_bot(self) -> bool:
        """Restart bot"""
        try:
            # Kill existing
            subprocess.run(["pkill", "-f", "main.py"], capture_output=True, timeout=5)
            time.sleep(2)

            # Start bot
            subprocess.Popen(
                ["python3", "main.py"],
                cwd=str(self.project_dir),
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )
            time.sleep(3)

            # Check running
            result = subprocess.run(
                ["pgrep", "-f", "main.py"],
                capture_output=True,
                timeout=5
            )
            return result.returncode == 0
        except:
            return False

    def _check_logs_for_error(self, error: str) -> List[str]:
        """Check log untuk error tertentu"""
        if not self.log_file.exists():
            return []

        found_errors = []
        try:
            with open(self.log_file, "r") as f:
                lines = f.readlines()[-100:]  # 100 baris terakhir

            # Cari error
            for line in lines:
                for pattern in self.error_patterns:
                    if pattern in line:
                        found_errors.append(line.strip())

            # Cari error spesifik (misal: _check_cooldown)
            if error:
                for line in lines:
                    if error in line:
                        found_errors.append(f"[SPECIFIC] {line.strip()}")

        except Exception as e:
            print(f"[VERIFY] Log check error: {e}")

        return found_errors


# Singleton
_verifier = None

def get_runtime_verifier():
    global _verifier
    if _verifier is None:
        _verifier = RuntimeVerifier()
    return _verifier
