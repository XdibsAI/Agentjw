{
    "app": {
        "name": "AgentJW",
        "version": "0.8.0",
        "environment": "production"
    },
    "api": {
        "host": "0.0.0.0",
        "port": 18791,
        "debug": false
    },
    "llm": {
        "default_model": "gpt-4",
        "temperature": 0.7,
        "max_tokens": 2000,
        "timeout": 30,
        "retry_count": 3
    },
    "logging": {
        "level": "INFO"
    },
    "security": {
        "session_timeout": 3600
    },
    "workflow": {
        "max_steps": 20,
        "timeout": 300
    },
    "metrics": {
        "enabled": true
    }
}
