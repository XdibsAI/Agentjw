{
  "rules": [
    {
      "pattern": "auto.?repair|auto.?fix|repair.*project|fix.*project",
      "intent": "auto_repair",
      "action": "auto_repair_project",
      "priority": 25,
      "description": "Auto-repair project"
    },
    {
      "pattern": "lepas.*fokus|keluar.*konteks|ngaco|salah|error.*konteks|obrolan.*lepas",
      "intent": "self_diagnostic",
      "action": "diagnostic",
      "priority": 20
    },
    {
      "pattern": "obralan.*ingat|apa.*kita.*bicarakan|ringkasan.*percakapan",
      "intent": "context_summary",
      "action": "summarize_context",
      "priority": 15
    },
    {
      "pattern": "kenapa kamu|kok kamu|kamu kenapa",
      "intent": "self_diagnostic",
      "action": "diagnostic",
      "priority": 10
    },
    {
      "pattern": "error|bug|masalah",
      "intent": "diagnostic",
      "action": "diagnostic",
      "priority": 8
    },
    {
      "pattern": "analisa.*project|audit.*project",
      "intent": "project_audit",
      "action": "analyze_project",
      "priority": 5
    },
    {
      "pattern": "status godmeme|godmeme status",
      "intent": "trading_status",
      "action": "godmeme_status",
      "priority": 5
    }
  ],
  "api_key_context": {
    "patterns": [
      "anthropic",
      "claude",
      "api key"
    ],
    "response": "Jika user bilang tidak pakai Anthropic, jangan sebut ANTHROPIC_API_KEY."
  }
}