"""
modify_logic - Modifikasi logic dengan Result Contract
"""

from pathlib import Path
from memory.unified_projects import unified_projects
from sicuan.core.repair_trace_guard import must_trace_before_repair
from agents.specialist.logic_modifier import logic_modifier
from sicuan.core.result_contract import ResultContract


def execute(task: dict) -> dict:
    """Execute modify_logic dengan Result Contract"""
    target = task.get("target", "")
    user_request = task.get("user_request", "")
    
    # target format: "nama_project: instruksi"
    proj_name = target
    instruction = user_request
    if target and ":" in target:
        proj_name, _, instruction_part = target.partition(":")
        if instruction_part.strip():
            instruction = instruction_part.strip()
    
    projects = unified_projects.list_projects()
    proj = None
    for p in projects:
        if proj_name and proj_name.lower() in p["name"].lower():
            proj = p
            break
    
    if not proj:
        contract = ResultContract(
            success=False,
            action="modify_logic",
            entity=proj_name,
            display=f"❌ Project tidak ditemukan: {proj_name}",
            errors=[f"Project tidak ditemukan: {proj_name}"]
        )
        return contract.to_dict()
    
    try:
        project_dir = Path(proj["project_dir"])
        trace_ctx = must_trace_before_repair(str(project_dir))
        result = logic_modifier.modify(project_dir, instruction)
        
        modified = result.get("modified", [])
        failed = result.get("failed", [])
        
        if modified:
            display = f"🔧 Logic modified: {len(modified)} files"
        elif failed:
            display = f"⚠️ Logic modification failed: {len(failed)} files"
        else:
            display = "🔧 Logic modified"
        
        contract = ResultContract(
            success=True,
            action="modify_logic",
            entity=proj['name'],
            display=display,
            metrics={
                "modified": len(modified),
                "failed": len(failed)
            },
            confidence=0.9,
            data={"modified": modified, "failed": failed, "trace": trace_ctx}
        )
        return contract.to_dict()
        
    except Exception as e:
        contract = ResultContract(
            success=False,
            action="modify_logic",
            entity=proj_name,
            display=f"❌ Gagal memodifikasi logic: {str(e)}",
            errors=[str(e)]
        )
        return contract.to_dict()

    # === EXECUTION VALIDATION ===
    try:
        from sicuan.core.execution_validator import get_validator
        validator = get_validator()
        validation_result = validator.validate({"patch": result})
        
        if validation_result["decision"] == "commit":
            # Simpan sebagai experience
            print(f"[VALIDATOR] ✅ Commit: {validation_result['reason']}")
        elif validation_result["decision"] == "warning":
            print(f"[VALIDATOR] ⚠️ Warning: {validation_result['reason']}")
        else:
            print(f"[VALIDATOR] ❌ Rollback: {validation_result['reason']}")
        
                # === APPLY & VERIFY PATCH ===
        try:
            from sicuan.core.patch_applier import get_patch_applier
            applier = get_patch_applier()
            
            # Apply patch
            patch_result = applier.apply_patch("godmeme_bot/strategy.py", result)
            
            if patch_result["success"] and patch_result["changed"]:
                print(f"[PATCH] ✅ File changed: {patch_result['file']}")
                result = f"✅ File changed: {patch_result['file']}
{result}"
            elif patch_result["success"] and not patch_result["changed"]:
                print(f"[PATCH] ⚠️ No changes applied: {patch_result['file']}")
                result = f"⚠️ No changes applied: {patch_result['file']}
{result}"
            else:
                print(f"[PATCH] ❌ Patch failed: {patch_result.get('error', 'Unknown')}")
                result = f"❌ Patch failed: {patch_result.get('error', 'Unknown')}
{result}"
        except Exception as e:
            print(f"[PATCH] Error: {e}")
        
        return result + f"\n\n🔍 **Validation:** {validation_result['decision']} - {validation_result['reason']}"
    except Exception as e:
        print(f"[VALIDATOR] Error: {e}")
                # === APPLY & VERIFY PATCH ===
        try:
            from sicuan.core.patch_applier import get_patch_applier
            applier = get_patch_applier()
            
            # Apply patch
            patch_result = applier.apply_patch("godmeme_bot/strategy.py", result)
            
            if patch_result["success"] and patch_result["changed"]:
                print(f"[PATCH] ✅ File changed: {patch_result['file']}")
                result = f"✅ File changed: {patch_result['file']}
{result}"
            elif patch_result["success"] and not patch_result["changed"]:
                print(f"[PATCH] ⚠️ No changes applied: {patch_result['file']}")
                result = f"⚠️ No changes applied: {patch_result['file']}
{result}"
            else:
                print(f"[PATCH] ❌ Patch failed: {patch_result.get('error', 'Unknown')}")
                result = f"❌ Patch failed: {patch_result.get('error', 'Unknown')}
{result}"
        except Exception as e:
            print(f"[PATCH] Error: {e}")
        
        return result

    # === EXECUTION VALIDATION ===
    try:
        from sicuan.core.execution_validator import get_validator
        validator = get_validator()
        validation_result = validator.validate({"patch": result})
        
        if validation_result["decision"] == "commit":
            result += f"\n\n✅ **Validation: COMMIT**\n{validation_result['reason']}"
        elif validation_result["decision"] == "warning":
            result += f"\n\n⚠️ **Validation: WARNING**\n{validation_result['reason']}"
        else:
            result += f"\n\n❌ **Validation: ROLLBACK**\n{validation_result['reason']}"
    except Exception as e:
        print(f"[VALIDATOR] Error: {e}")
        result += f"\n\n⚠️ Validation error: {e}"

            # === APPLY & VERIFY PATCH ===
        try:
            from sicuan.core.patch_applier import get_patch_applier
            applier = get_patch_applier()
            
            # Apply patch
            patch_result = applier.apply_patch("godmeme_bot/strategy.py", result)
            
            if patch_result["success"] and patch_result["changed"]:
                print(f"[PATCH] ✅ File changed: {patch_result['file']}")
                result = f"✅ File changed: {patch_result['file']}
{result}"
            elif patch_result["success"] and not patch_result["changed"]:
                print(f"[PATCH] ⚠️ No changes applied: {patch_result['file']}")
                result = f"⚠️ No changes applied: {patch_result['file']}
{result}"
            else:
                print(f"[PATCH] ❌ Patch failed: {patch_result.get('error', 'Unknown')}")
                result = f"❌ Patch failed: {patch_result.get('error', 'Unknown')}
{result}"
        except Exception as e:
            print(f"[PATCH] Error: {e}")
        
        return result
