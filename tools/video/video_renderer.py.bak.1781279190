"""
tools/video/video_renderer.py - AgentJW Video Renderer
Turns a generated video_package (script + scenes text) into an actual
final_video.mp4 using:
  - OpenAI TTS (tts-1) for narration audio per segment
  - Pillow for static captioned background images per segment
  - moviepy + ffmpeg for assembly (image+audio per segment, concatenated)

No external image/video-gen API required (per project decision: skip
Higgsfield/Replicate for now, static images + TTS + ffmpeg only).
"""
import re
import textwrap
import asyncio
import edge_tts
from pathlib import Path
from typing import List, Dict

from PIL import Image, ImageDraw, ImageFont
from moviepy import ImageClip, AudioFileClip, concatenate_videoclips

from core.config import config
from core.logger import logger, console
from tools.video.openrouter_client import OpenRouterClient

DEFAULT_VOICE = "en-US-GuyNeural"   # free MS edge-tts voice (no API key needed)
# Other options: "en-US-ChristopherNeural", "id-ID-ArdiNeural" (Indonesian)
VIDEO_SIZE = (1280, 720)
BG_COLORS = [
    (20, 24, 38), (35, 20, 45), (15, 35, 40),
    (40, 25, 20), (22, 30, 50), (30, 30, 30),
]


class VideoRendererTool:
    """Renders a video_package dict (from VideoStudioTool) into final_video.mp4"""

    def __init__(self):
        pass

    # ── 1. PARSE SCRIPT INTO NARRATION SEGMENTS ────────────────────────────
    


    def extract_scene_prompts(self, package: Dict) -> List[str]:
        scenes_text = package.get("sections", {}).get("scenes", "")

        prompts = re.findall(
            r'HIGGSFIELD PROMPT:\s*(.*?)(?=\n\s*\*\s*\*\s*CAMERA|\nCAMERA:|$)',
            scenes_text,
            flags=re.I | re.S
        )

        cleaned = []

        for ptxt in prompts:
            ptxt = re.sub(r'\s+', ' ', ptxt).strip()

            if len(ptxt) > 30:
                cleaned.append(ptxt)

        return cleaned

    def extract_segments(self, package: Dict, max_segments: int = 100) -> List[str]:
        """
        Extract narration from EN VO blocks and legacy formats.
        """
        script = package.get("sections", {}).get("script", "")
        segments: List[str] = []

        import re

        matches = re.findall(
            r'\*\*EN VO:\*\*(?:.*?)"([^"]+)"',
            script,
            flags=re.IGNORECASE
        )

        for m in matches:
            m = m.strip()
            if len(m) > 10:
                segments.append(m)

        if not segments:
            matches = re.findall(
                r'EN VO:\s*"([^"]+)"',
                script,
                flags=re.IGNORECASE
            )

            for m in matches:
                m = m.strip()
                if len(m) > 10:
                    segments.append(m)

        if not segments:
            for line in script.splitlines():
                line = line.strip().lstrip("-•* ").strip()

                if "|" in line:
                    vo = line.split("|")[0].strip()

                    if len(vo) > 5:
                        segments.append(vo)

        if not segments:
            segments = [
                package.get("intent", {}).get(
                    "title",
                    "Untitled video"
                )
            ]

        return segments[:max_segments]


    def extract_scene_prompts(self, package: Dict) -> List[str]:
        scenes = package.get("sections", {}).get("scenes", "")

        prompts = re.findall(
            r'HIGGSFIELD PROMPT:\*\*.*?\((?:\d+ words)?\)\s*(.*?)(?=\*\s*\*CAMERA:|CAMERA:)',
            scenes,
            flags=re.S | re.I
        )

        cleaned = []

        for p in prompts:
            p = " ".join(p.split())
            if len(p) > 50:
                cleaned.append(p)

        return cleaned

    def generate_audio(self, text: str, out_path: Path, voice: str = DEFAULT_VOICE) -> Path:
        async def _run():
            communicate = edge_tts.Communicate(text, voice)
            await communicate.save(str(out_path))
        asyncio.run(_run())
        if not out_path.exists() or out_path.stat().st_size == 0:
            raise RuntimeError("edge-tts produced empty output")
        return out_path

    # ── 3. CAPTIONED BACKGROUND IMAGE ───────────────────────────────────────
    
    def generate_scene_image(
        self,
        text: str,
        index: int,
        out_path: Path,
        scene_prompt: str = ""
    ) -> Path:

        try:
            client = OpenRouterClient(
                api_key=config.OPENROUTER_API_KEY,
                model=config.OPENROUTER_IMAGE_MODEL
            )

            prompt = scene_prompt or text

            client.generate_image(
                prompt=prompt,
                output_path=str(out_path),
                model=config.OPENROUTER_IMAGE_MODEL
            )

            if out_path.exists() and out_path.stat().st_size > 1000:
                return out_path

        except Exception as e:
            logger.warning(f"Image generation failed: {e}")

        color = BG_COLORS[index % len(BG_COLORS)]
        img = Image.new("RGB", VIDEO_SIZE, color)
        draw = ImageDraw.Draw(img)

        try:
            font = ImageFont.truetype(
                "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
                48
            )
        except Exception:
            font = ImageFont.load_default()

        wrapped = textwrap.fill(text, width=32)

        draw.multiline_text(
            (60, 250),
            wrapped,
            fill=(255,255,255),
            font=font
        )

        img.save(out_path)

        return out_path

    # ── 4. RENDER FULL VIDEO ─────────────────────────────────────────────────
    def render(self, package: Dict, project_dir: Path, voice: str = DEFAULT_VOICE) -> Path:
        project_dir = Path(project_dir)
        assets_dir = project_dir / "render_assets"
        assets_dir.mkdir(parents=True, exist_ok=True)

        scene_prompts = self.extract_scene_prompts(package)
        segments = self.extract_segments(package)
        scene_prompts = self.extract_scene_prompts(package)
        if not segments:
            raise RuntimeError("No narration segments found in package script")

        clips = []
        console.print(f"[cyan]Rendering {len(segments)} segments...[/cyan]")

        for i, text in enumerate(segments):
            audio_path = assets_dir / f"seg_{i:02d}.mp3"
            image_path = assets_dir / f"seg_{i:02d}.png"

            try:
                self.generate_audio(text, audio_path, voice=voice)
            except Exception as e:
                logger.error(f"TTS failed for segment {i}: {e}")
                continue

            self.generate_scene_image(
                text,
                i,
                image_path,
                scene_prompts[i] if i < len(scene_prompts) else text
            )

            audio_clip = AudioFileClip(str(audio_path))
            duration = max(audio_clip.duration, 1.5)
            image_clip = (
                ImageClip(str(image_path))
                .resized((1280, 720))
                .with_duration(duration)
                .with_audio(audio_clip)
            )
            clips.append(image_clip)
            console.print(f"  [green]✓[/green] segment {i+1}/{len(segments)} "
                          f"({duration:.1f}s)")

        if not clips:
            raise RuntimeError("No segments rendered successfully (check OPENAI_API_KEY)")

        final = concatenate_videoclips(clips, method="compose")
        out_path = project_dir / "final_video.mp4"
        final.write_videofile(
            str(out_path),
            fps=24,
            codec="libx264",
            audio_codec="aac",
            logger=None
        )

        for c in clips:
            c.close()
        final.close()

        console.print(f"[bold green]✅ Video rendered: {out_path}[/bold green]")
        return out_path


video_renderer_tool = VideoRendererTool()
